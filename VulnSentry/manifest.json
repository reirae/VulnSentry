{
  "manifest_version": 3,
  "name": "VulnSentry",
  "version": "1.0",
  "description": "Passive vulnerability scanner and header analyzer.",
  "permissions": [
    "activeTab",
    "storage",
    "webRequest" 
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}